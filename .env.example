# ===========================================
# Server Proxy Manager - Environment Variables
# ===========================================
# Copy this file to .env and customize as needed:
# cp .env.example .env

# ===========================================
# Port Configuration
# ===========================================

# HTTP port (default: 80)
HTTP_PORT=80

# HTTPS port (default: 443)
HTTPS_PORT=443

# Admin UI port (default: 81, bound to 127.0.0.1)
# Access via SSH tunnel: ssh -L 8181:localhost:81 user@server
# To expose publicly, set: ADMIN_PORT=81 (not recommended)
ADMIN_PORT=81

# ===========================================
# General Settings
# ===========================================

# Timezone (default: UTC)
# Examples: Europe/Moscow, America/New_York, Asia/Tokyo
TIMEZONE=UTC

# ===========================================
# Domain (used by monitoring stack)
# ===========================================

# Your server domain (e.g., example.com)
# DOMAIN=example.com

# ===========================================
# Monitoring - Grafana (Optional)
# ===========================================

# Grafana admin credentials (used in examples/monitoring)
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=your_secure_password_here

# ===========================================
# Database Configuration (Optional)
# ===========================================
# By default, Nginx Proxy Manager uses SQLite.
# For production with many hosts, consider MySQL/MariaDB.

# Uncomment to use MySQL/MariaDB:
# DB_MYSQL_HOST=db
# DB_MYSQL_PORT=3306
# DB_MYSQL_USER=npm
# DB_MYSQL_PASSWORD=your_secure_password_here
# DB_MYSQL_NAME=npm

# ===========================================
# Default Admin Credentials (first login only)
# ===========================================
# Email:    admin@example.com
# Password: changeme
#
# IMPORTANT: Change these immediately after first login!
